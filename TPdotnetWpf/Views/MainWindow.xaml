<Window x:Class="TPdotnetWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionnaire de Livres — WPF"
        Height="680" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F7">

    <Window.Resources>
        <!-- Style TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <!-- Style ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!-- Style Button principal -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Titre app -->
            <RowDefinition Height="Auto"/>   <!-- Barre recherche -->
            <RowDefinition Height="*"/>      <!-- Contenu principal -->
            <RowDefinition Height="Auto"/>   <!-- Statistiques -->
        </Grid.RowDefinitions>

        <!-- ── En-tête ─────────────────────────────────────────────── -->
        <TextBlock Grid.Row="0"
                   Text="Gestionnaire de Livres"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#1E1E50"
                   Margin="0,0,0,12"/>

        <!-- ── Barre de recherche ───────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,0,0,12"
                BorderBrush="#CBD5E1" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="" FontSize="14" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="0"
                             Width="400"
                             Text="{Binding TermeRecherche,
                                            UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"
                             BorderThickness="0"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Grid>
                                                <TextBlock Text="Rechercher par titre ou auteur..."
                                                           Foreground="#94A3B8"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TermeRecherche}"
                                                                             Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              VerticalAlignment="Center"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                
            </Grid>
        </Border>

        <!-- ── Corps principal : formulaire + liste ─────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ Colonne 0 — Formulaire ══════════════════════════ -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="20"
                    BorderBrush="#CBD5E1" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Formulaire"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#1E1E50"
                               Margin="0,0,0,16"/>

                    <!-- Titre -->
                    <TextBlock Text="Titre *" Foreground="#475569" FontSize="12" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Titre, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <!-- Auteur -->
                    <TextBlock Text="Auteur *" Foreground="#475569" FontSize="12" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Auteur, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <!-- Année -->
                    <TextBlock Text="Année *" Foreground="#475569" FontSize="12" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding AnneeTexte, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"/>

                    <!-- Genre -->
                    <TextBlock Text="Genre *" Foreground="#475569" FontSize="12" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding Genres}"
                              SelectedItem="{Binding Genre}"
                              Margin="0,0,0,10"/>

                    <!-- Lu -->
                    <CheckBox Content="Lu ?"
                              IsChecked="{Binding Lu}"
                              FontSize="13"
                              Margin="0,0,0,20"/>

                    <!-- Boutons -->
                    <Button Content="Ajouter"
                            Command="{Binding AjouterCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Background="#22C55E"
                            Margin="0,0,0,8"/>

                    <Button Content="Modifier"
                            Command="{Binding ModifierCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Background="#3B82F6"
                            Margin="0,0,0,8"/>

                    <Button Content="Supprimer"
                            Command="{Binding SupprimerCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Background="#EF4444"
                            Margin="0,0,0,8"/>

                    <Button Content="Vider"
                            Command="{Binding ViderCommand}"
                            Style="{StaticResource BtnPrimary}"
                            Background="#94A3B8"/>
                </StackPanel>
            </Border>

            <!-- ═══ Colonne 2 — DataGrid ════════════════════════════ -->
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="8"
                    Padding="16"
                    BorderBrush="#CBD5E1" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Liste des livres"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#1E1E50"
                               Margin="0,0,0,12"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Livres}"
                              SelectedItem="{Binding LivreSelectionne, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F1F5F9"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              FontSize="13">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Titre"  Binding="{Binding Titre}"  Width="*"/>
                            <DataGridTextColumn Header="Auteur" Binding="{Binding Auteur}" Width="160"/>
                            <DataGridTextColumn Header="Année"  Binding="{Binding Annee}"  Width="70"/>
                            <DataGridTextColumn Header="Genre"  Binding="{Binding Genre}"  Width="90"/>
                            <DataGridCheckBoxColumn Header="Lu" Binding="{Binding Lu}"     Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Statistiques ─────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#1E1E50"
                CornerRadius="6"
                Padding="16,10"
                Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Foreground="White" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <Run Text="Total : "/>
                    <Run Text="{Binding TotalLivres, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" livre(s)   |   Lus : "/>
                    <Run Text="{Binding LivresLus, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" livre(s)   |   Progression : "/>
                    <Run Text="{Binding PourcentageLus, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text="% complétés"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
